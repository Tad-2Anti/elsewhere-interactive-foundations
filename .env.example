# ELSEWHERE — Environment Variables
#
# Copy this file to .env.local for local development.
# On Vercel, set these as Environment Variables in the project dashboard.
# Never commit .env.local or any file containing real secrets.

# ── Public site identity ──────────────────────────────────────────────────────
# Canonical production origin used by metadata, robots.txt, and sitemap.xml.
NEXT_PUBLIC_SITE_URL=https://elsewhere.sh

# ── Database ──────────────────────────────────────────────────────────────────
# PostgreSQL connection string for durable sourcing-request storage.
# Configure this, WEB3FORMS_ACCESS_KEY, or preferably both in production.
# Neon.tech and Vercel Postgres are both supported; SSL is auto-detected.
# Example (Neon):  postgresql://user:pass@ep-xyz.neon.tech/dbname?sslmode=require
# Example (local): postgresql://localhost:5432/elsewhere
DATABASE_URL=

# ── Web3Forms ─────────────────────────────────────────────────────────────────
# Access key for forwarding sourcing requests to your email via web3forms.com.
# Configure this, DATABASE_URL, or preferably both in production. A submission
# succeeds when at least one configured delivery channel accepts it.
# Set secrets only in the deployment environment.
WEB3FORMS_ACCESS_KEY=

# ── Optional overrides ────────────────────────────────────────────────────────
# Force mock DB even when DATABASE_URL is set (useful for CI without a real DB).
# MOCK_DB=true
